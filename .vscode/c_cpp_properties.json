{
    "configurations": [
        {
            "name": "AArch64",
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/src/aarch64",
                "${workspaceFolder}/src/aarch64/limine",
                "${workspaceFolder}/limine-protocol/include"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/aarch64-linux-gnu-gcc",
            "compilerArgs": [
                "-ffreestanding",
                "-nostdlib",
                "-march=armv8-a",
                "-mgeneral-regs-only"
            ],
            "cStandard": "c11",
            "intelliSenseMode": "linux-gcc-arm64"
        },
        {
            "name": "x86_64",
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/src/x86_64",
                "${workspaceFolder}/src/x86_64/limine",
                "${workspaceFolder}/limine-protocol/include"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",
            "compilerArgs": [
                "-ffreestanding",
                "-nostdlib",
                "-m64",
                "-mno-red-zone"
            ],
            "cStandard": "c11",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}