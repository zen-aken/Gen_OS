{
    "configurations": [
        {
            "name": "AArch64",
            "includePath": [
                "/root/Gen_OS/src",
                "/root/Gen_OS/src/aarch64",
                "/root/Gen_OS/src/aarch64/limine",
                "/root/Gen_OS/limine-protocol/include"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/aarch64-linux-gnu-gcc",
            "compilerArgs": [
                "-ffreestanding",
                "-nostdlib",
                "-march=armv8-a",
                "-mgeneral-regs-only"
            ],
            "cStandard": "c23",
            "intelliSenseMode": "linux-gcc-arm64",
            "compilerPathInCppPropertiesJson": "/usr/bin/aarch64-linux-gnu-gcc",
            "mergeConfigurations": false,
            "recursiveIncludes": {},
            "browse": {
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "x86_64",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/src",
                "${workspaceFolder}/src/x86_64",
                "${workspaceFolder}/src/x86_64/limine",
                "${workspaceFolder}/limine-protocol/include"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",
            "compilerArgs": [
                "-ffreestanding",
                "-nostdlib",
                "-m64",
                "-mno-red-zone"
            ],
            "cStandard": "c23",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}